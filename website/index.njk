            <!-- Right: Interactive Demo -->
            <div class="lg:pl-8">
                <div class="bg-[var(--card-bg)] rounded-2xl shadow-2xl p-8 border border-[var(--border-color)]" 
                     x-data="{ 
                         url: '', 
                         shortUrl: '', 
                         expiresAt: '',
                         isLoading: false,
                         error: '',
                         success: false,
                         async createShortUrl() {
                             this.isLoading = true;
                             this.error = '';
                             this.success = false;
                             
                             try {
                                 if (!this.url) {
                                     this.error = 'Please enter a URL';
                                     this.isLoading = false;
                                     return;
                                 }
                                 
                                 if (!this.url.startsWith('http://') && !this.url.startsWith('https://')) {
                                     this.url = 'https://' + this.url;
                                 }
                                 
                                 const response = await fetch('https://rdrx.co/api/temp', {
                                     method: 'POST',
                                     headers: { 'Content-Type': 'application/json' },
                                     body: JSON.stringify({ url: this.url })
                                 });
                                 
                                 if (!response.ok) throw new Error('Failed to create short URL');
                                 
                                 const data = await response.json();
                                 this.shortUrl = data.full_url;
                                 this.expiresAt = new Date(data.expires_at).toLocaleString();
                                 this.success = true;
                             } catch (error) {
                                 this.error = error.message || 'An error occurred';
                             } finally {
                                 this.isLoading = false;
                             }
                         },
                         copyToClipboard() {
                             navigator.clipboard.writeText(this.shortUrl);
                             const btn = $event.target;
                             const originalHTML = btn.innerHTML;
                             btn.innerHTML = '<i class=\"fas fa-check\"></i>';
                             setTimeout(() => btn.innerHTML = originalHTML, 2000);
                         }
                     }">
                    
                    <div class="text-center mb-6">
                        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[var(--primary-100)] mb-4">
                            <i class="fas fa-link text-[var(--primary-500)] text-2xl"></i>
                        </div>
                        <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-2">Try It Now</h2>
                        <p class="text-[var(--text-secondary)] text-sm">
                            No account required • Links expire in 2 days
                        </p>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="relative">
                            <input 
                                type="text" 
                                x-model="url" 
                                placeholder="Enter your long URL here..." 
                                class="w-full px-4 py-3 rounded-lg border-2 border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:border-[var(--primary-500)] focus:outline-none transition-colors"
                                @keyup.enter="createShortUrl"
                            >
                            <div class="absolute inset-y-0 right-0 flex items-center pr-3 pointer-events-none">
                                <i class="fas fa-globe text-[var(--text-tertiary)]"></i>
                            </div>
                        </div>
                        
                        <button 
                            @click="createShortUrl" 
                            class="w-full px-4 py-3 rounded-lg bg-[var(--primary-500)] text-white font-semibold hover:bg-[var(--primary-600)] transition-all transform hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none"
                            :disabled="isLoading"
                        >
                            <span x-show="!isLoading">
                                <i class="fas fa-magic mr-2"></i>Shorten URL
                            </span>
                            <span x-show="isLoading">
                                <i class="fas fa-spinner fa-spin mr-2"></i>Processing...
                            </span>
                        </button>
                        
                        <p x-show="error" x-text="error" class="text-red-500 text-sm"></p>
                    </div>
                    
                    <div x-show="success" 
                         x-transition
                         class="mt-6 p-4 bg-green-50 dark:bg-green-900/20 rounded-lg border-2 border-green-200 dark:border-green-800">
                        <h3 class="text-lg font-semibold text-green-800 dark:text-green-400 mb-3">
                            <i class="fas fa-check-circle mr-2"></i>Success!
                        </h3>
                        <div class="flex items-center gap-2">
                            <input 
                                type="text" 
                                x-model="shortUrl" 
                                readonly 
                                class="flex-1 px-3 py-2 rounded-lg border border-green-300 dark:border-green-700 bg-white dark:bg-green-950 text-sm"
                            >
                            <button 
                                @click="copyToClipboard" 
                                class="px-4 py-2 rounded-lg bg-green-600 hover:bg-green-700 text-white transition-colors"
                            >
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <p class="text-sm text-green-700 dark:text-green-300 mt-2">
                            <i class="fas fa-clock mr-1"></i>Expires: <span x-text="expiresAt"></span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

